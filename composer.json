{
    "name": "studentlink/app",
    "description": "StudentLink — Plateforme d'événements étudiants",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "files": [
            "includes/gamification.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test:coverage": "phpunit --coverage-html coverage",
        "stan": "phpstan analyse --memory-limit=512M",
        "ci": [
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
